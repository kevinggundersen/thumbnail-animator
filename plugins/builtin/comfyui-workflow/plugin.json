{
  "id": "comfyui-workflow",
  "name": "ComfyUI Workflow Extractor",
  "version": "1.0.0",
  "description": "Extracts ComfyUI workflow and prompt data from PNG metadata chunks (tEXt, zTXt, iTXt).",
  "main": "index.js",
  "capabilities": {
    "metadataExtractors": [
      {
        "id": "comfyui-workflow",
        "name": "ComfyUI Workflow",
        "extensions": [".png"],
        "method": "extractWorkflow"
      }
    ],
    "infoSections": [
      {
        "id": "comfyui-info",
        "title": "ComfyUI Workflow",
        "appliesTo": { "hasMetadata": "comfyui-workflow" },
        "method": "renderInfoSection"
      }
    ],
    "tooltipSections": [
      {
        "id": "comfyui-tooltip",
        "label": "ComfyUI Tooltip",
        "appliesTo": { "hasMetadata": "comfyui-workflow" },
        "method": "buildTooltipHtml"
      }
    ],
    "contextMenuItems": [
      {
        "id": "copy-workflow-json",
        "label": "Copy Workflow JSON",
        "appliesTo": { "hasMetadata": "comfyui-workflow" },
        "method": "copyWorkflowJSON",
        "position": "after:reveal"
      }
    ],
    "fileTypes": [],
    "settingsPanel": {
      "label": "ComfyUI Workflow",
      "loadMethod": "loadSettings",
      "saveMethod": "saveSettings",
      "html": "<div class=\"settings-content-heading\">ComfyUI Workflow Settings</div><div class=\"settings-item\"><label class=\"settings-label\"><div class=\"settings-item-info\"><div class=\"settings-item-title\">Show in Card Hover Tooltip</div><div class=\"settings-item-description\">Display a badge on the hover tooltip when a file has an embedded ComfyUI workflow.</div></div><div class=\"toggle-switch\"><input type=\"checkbox\" data-plugin-setting-key=\"showInTooltip\" checked><span class=\"toggle-slider\"></span></div></label></div>"
    }
  }
}
