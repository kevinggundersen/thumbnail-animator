{
  "name": "thumbnail-animator",
  "version": "1.4.0",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "dist": "electron-builder --publish=never",
    "release": "electron-builder --publish=always"
  },
  "keywords": [
    "electron",
    "thumbnail",
    "media-browser",
    "image-viewer",
    "video-player",
    "desktop-app"
  ],
  "author": "Kevin Gundersen",
  "license": "ISC",
  "description": "Thumbnail Animator - An Electron app for creating animated thumbnails",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^3.6.0",
    "exifreader": "^4.37.0",
    "gifuct-js": "^2.1.2",
    "image-size": "^2.0.2",
    "png-chunks-extract": "^1.0.0",
    "sharp": "^0.34.5",
    "webpxmux": "^0.0.2",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^39.2.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.thumbnailanimator.app",
    "productName": "Thumbnail Animator",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "kevinggundersen",
      "repo": "thumnail-animator"
    },
    "files": [
      "**/*",
      "!electron-cache/**/*",
      "!dist/**/*",
      "!*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
