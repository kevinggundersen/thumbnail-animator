{
  "id": "exif-metadata",
  "name": "EXIF Metadata Viewer",
  "version": "2.0.0",
  "description": "Displays EXIF, IPTC, XMP and GPS metadata from images (JPEG, PNG, WebP, TIFF, HEIC, AVIF). Powered by ExifReader.",
  "main": "index.js",
  "capabilities": {
    "metadataExtractors": [
      {
        "id": "exif-metadata",
        "name": "EXIF / IPTC / XMP Metadata",
        "extensions": [".jpg", ".jpeg", ".tiff", ".tif", ".png", ".webp", ".heic", ".heif", ".avif"],
        "method": "extractEXIF"
      }
    ],
    "infoSections": [
      {
        "id": "exif-info",
        "title": "EXIF / Metadata",
        "appliesTo": { "hasMetadata": "exif-metadata" },
        "method": "renderEXIFSection"
      }
    ],
    "tooltipSections": [
      {
        "id": "exif-tooltip",
        "label": "EXIF Tooltip",
        "appliesTo": { "hasMetadata": "exif-metadata" },
        "method": "buildTooltipHtml"
      }
    ],
    "contextMenuItems": [
      {
        "id": "copy-exif-json",
        "label": "Copy EXIF Data",
        "appliesTo": { "hasMetadata": "exif-metadata" },
        "method": "copyEXIFJSON",
        "position": "after:reveal"
      }
    ],
    "fileTypes": [],
    "settingsPanel": {
      "label": "EXIF Metadata",
      "loadMethod": "loadSettings",
      "saveMethod": "saveSettings",
      "html": "<div class=\"settings-content-heading\">EXIF Metadata Settings</div><div class=\"settings-item\"><label class=\"settings-label\"><div class=\"settings-item-info\"><div class=\"settings-item-title\">Show in Card Hover Tooltip</div><div class=\"settings-item-description\">Display a badge on the hover tooltip when a file has EXIF data.</div></div><div class=\"toggle-switch\"><input type=\"checkbox\" data-plugin-setting-key=\"showInTooltip\" checked><span class=\"toggle-slider\"></span></div></label></div>"
    }
  }
}
